#!/bin/bash
# Runs as root after the .pkg payload (rCodexPDF.app + rcodexpdf CLI) is laid down.
set -e

CLI_PATH="/usr/local/bin/rcodexpdf"
if [[ -f "$CLI_PATH" ]]; then
  chmod 755 "$CLI_PATH"
fi

# Generate shell completions for whichever shells are present.
if [[ -x "$CLI_PATH" ]]; then
  mkdir -p /usr/local/share/zsh/site-functions
  "$CLI_PATH" --generate-completion-script zsh > /usr/local/share/zsh/site-functions/_rcodexpdf 2>/dev/null || true

  mkdir -p /usr/local/etc/bash_completion.d
  "$CLI_PATH" --generate-completion-script bash > /usr/local/etc/bash_completion.d/rcodexpdf 2>/dev/null || true
fi

xattr -dr com.apple.quarantine /Applications/rCodexPDF.app 2>/dev/null || true

exit 0
